                    "name": "Read Movie - Not Found (404)",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:3000/api/v1/movies/9999",
                        "description": "Error 404: ID inexistente[cite: 24]."
                    }
                },
                {
