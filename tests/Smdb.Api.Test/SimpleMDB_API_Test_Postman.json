{
    "info": {
        "name": "SimpleMDB_API_Test_Postman",
        "description": "Colección para pruebas de API: 5 exitosas y 5 fallidas (CRUD+L) [cite: 22, 28]",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Success Requests (200/201)",
            "item": [
                {
                    "name": "List Movies - Success",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:3000/api/v1/movies?page=1&size=10",
                        "description": "Lista películas con paginación[cite: 3, 4]."
                    }
                },
                {
                    "name": "Create Movie - Success",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Inception\",\n    \"year\": 2010,\n    \"description\": \"A thief who steals corporate secrets through the use of dream-sharing technology.\"\n}"
                        },
                        "url": "http://localhost:3000/api/v1/movies",
                        "description": "Crea una nueva película[cite: 3]."
                    }
                },
                {
                    "name": "Read Movie - Success",
                    "request": {
                        "method": "GET",
                        "url": "http://localhost:3000/api/v1/movies/1",
                        "description": "Obtiene una película por su ID[cite: 3, 4]."
                    }
                },
                {
                    "name": "Update Movie - Success",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Inception Updated\",\n    \"year\": 2010,\n    \"description\": \"Updated description text.\"\n}"
                        },
                        "url": "http://localhost:3000/api/v1/movies/1",
                        "description": "Actualiza una película existente[cite: 3]."
                    }
                },
                {
                    "name": "Delete Movie - Success",
                    "request": {
                        "method": "DELETE",
                        "url": "http://localhost:3000/api/v1/movies/1",
                        "description": "Elimina una película por ID[cite: 3]."
                    }
                }
            ]
        },
        {
